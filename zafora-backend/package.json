{
  "name": "zafora-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "dev:tsx": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "migrate:passwords": "tsx --env-file=.env scripts/migrate-passwords.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "resend": "^6.12.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.7",
    "esbuild-plugin-pino": "^2.3.3",
    "nodemon": "^3.1.14",
    "openapi-types": "^12.1.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "^3.1.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
