# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
SESSION_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_SECRET=change-me-to-a-min-32-char-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-min-32-char-string
# Used for first-time admin setup and emergency password reset
ADMIN_SETUP_EMAIL=admin@yourdomain.com

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# AWS S3 (Phase B6)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# CORS
ALLOWED_ORIGINS=