# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ─── Database (Neon PostgreSQL) ───────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_SECRET=change-me-to-a-min-32-char-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-min-32-char-string
# Email used for first-time admin setup and password reset (not for day-to-day login)
ADMIN_SETUP_EMAIL=admin@yourdomain.com

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── AWS S3 File Storage (Phase B6) ──────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ══════════════════════════════════════════════════════════
# GitHub Actions Secrets  (GitHub → Settings → Secrets → Actions)
# These are NOT used by the app — CI/CD pipeline only
# ══════════════════════════════════════════════════════════

# Railway personal API token  (railway.app/account/tokens)
# RAILWAY_TOKEN=

# Railway project ID — same project hosts both services
# (Railway dashboard → zafora-backend project → Settings → Project ID)
# RAILWAY_PROJECT_ID=cfa59364-5ffc-4296-ba92-259e91867366

# ══════════════════════════════════════════════════════════
# GitHub Actions Variables  (GitHub → Settings → Variables → Actions)
# Public URLs shown in workflow deployment summaries
# ══════════════════════════════════════════════════════════

# DEV_BACKEND_URL=https://zafora-dev-production.up.railway.app
# PROD_BACKEND_URL=https://zafora-production-production.up.railway.app
