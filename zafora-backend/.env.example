# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ─── Database (Neon PostgreSQL) ───────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_SECRET=change-me-to-a-min-32-char-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-min-32-char-string
# Email used for first-time admin setup and password reset (not for day-to-day login)
ADMIN_SETUP_EMAIL=admin@yourdomain.com

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── AWS S3 File Storage (Phase B6) ──────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ══════════════════════════════════════════════════════════
# GitHub Actions Secrets (set in GitHub → Settings → Secrets → Actions)
# These are NOT used by the app — only by the CI/CD pipeline
# ══════════════════════════════════════════════════════════

# Railway personal API token (Settings → Account → Tokens)
# RAILWAY_TOKEN=

# Dev Railway project ID (Railway dashboard → dev project → Settings → copy Project ID)
# RAILWAY_PROJECT_ID_DEV=

# Prod Railway project ID (Railway dashboard → prod project → Settings → copy Project ID)
# RAILWAY_PROJECT_ID_PROD=

# Service name in the dev Railway project (exact name shown in the service card)
# RAILWAY_BACKEND_SERVICE_NAME_DEV=zafora-backend

# Service name in the prod Railway project
# RAILWAY_BACKEND_SERVICE_NAME_PROD=zafora-backend

# ══════════════════════════════════════════════════════════
# GitHub Actions Variables (set in GitHub → Settings → Variables → Actions)
# These are NOT secrets — used for public deployment URLs in workflow summaries
# ══════════════════════════════════════════════════════════

# DEV_BACKEND_URL=https://your-dev-backend.up.railway.app
# PROD_BACKEND_URL=https://your-prod-backend.up.railway.app
