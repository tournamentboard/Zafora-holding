import { apiClient } from "@/src/lib/api-helpers";
import { API } from "@/src/lib/url-helpers";

export async function getSectionVisibility(): Promise<Record<string, Record<string, boolean>>> {
  try {
    const setting = await apiClient.get(API.CONTENT.SETTINGS("section_visibility"));
    return JSON.parse(setting.value || "{}");
  } catch { return {}; }
}
